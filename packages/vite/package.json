{
  "name": "@agentmarkup/vite",
  "version": "0.2.0",
  "description": "Build-time llms.txt, JSON-LD, and AI crawler controls for Vite",
  "type": "module",
  "license": "MIT",
  "author": "Sebastian Cochinescu <hello@animafelix.com> (https://animafelix.com)",
  "homepage": "https://agentmarkup.dev",
  "bugs": {
    "url": "https://github.com/agentmarkup/agentmarkup/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentmarkup/agentmarkup",
    "directory": "packages/vite"
  },
  "keywords": [
    "vite-plugin",
    "llms-txt",
    "json-ld",
    "schema-org",
    "structured-data",
    "robots-txt",
    "ai-crawler",
    "machine-readable",
    "seo"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm -C ../core build",
    "build": "tsup",
    "predev": "pnpm -C ../core build",
    "dev": "tsup --watch",
    "pretest": "pnpm -C ../core build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "pretypecheck": "pnpm -C ../core build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentmarkup/core": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "vite": "^6.2.0",
    "vitest": "^3.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "eslint": "^9.0.0"
  }
}
